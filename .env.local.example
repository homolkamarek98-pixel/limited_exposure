# ══════════════════════════════════════════════════════════
# .env.local — Limited Exposure
# Zkopíruj tento soubor jako .env.local a vyplň hodnoty.
# NIKDY necommituj .env.local do gitu!
# ══════════════════════════════════════════════════════════

# ── Databáze (Neon PostgreSQL) ─────────────────────────────
# Získáš z: neon.tech → projekt → Connection Details → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Vygeneruj: openssl rand -base64 32
NEXTAUTH_SECRET="vloz-sem-vygenerovany-secret"

# ── Cloudflare R2 (doplní se ve Fázi 3) ───────────────────
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_URL=""

# ── Stripe (doplní se ve Fázi 4) ──────────────────────────
# STRIPE_PUBLIC_KEY=""
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
