generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Limited Exposure — datový model
// ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         Role     @default(BUYER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  photographer Photographer?
  orders       Order[]
}

enum Role {
  BUYER
  PHOTOGRAPHER
  ADMIN
}

model Photographer {
  id         String @id @default(cuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id])
  bio        String @default("")
  instagram  String @default("")
  totalSales Int    @default(0)

  photos Photo[]
}

model Photo {
  id             String       @id @default(cuid())
  title          String
  photographerId String
  photographer   Photographer @relation(fields: [photographerId], references: [id])
  description    String       @default("")
  imageUrl       String
  format         Format

  editions Edition[]
}

enum Format {
  S
  M
  L
}

model Edition {
  id             String      @id @default(cuid())
  photoId        String
  photo          Photo       @relation(fields: [photoId], references: [id])
  type           EditionType
  price          Int // Medium — základ v haléřích (50×70 cm)
  priceS         Int? // Small override — 30×40 cm (null = 85 % z price)
  priceL         Int? // Large override — 70×100 cm (null = 125 % z price)
  totalCount     Int? // max kusů (pouze pro limited_count)
  soldCount      Int         @default(0)
  availableUntil DateTime? // deadline (pouze pro time_window)
  tier           Tier

  orderItems OrderItem[]
}

enum EditionType {
  LIMITED_COUNT
  TIME_WINDOW
}

enum Tier {
  RISING_TALENT
  SIGNATURE
}

model Order {
  id    String  @id @default(cuid())
  buyerId String?
  buyer   User?   @relation(fields: [buyerId], references: [id])

  // Kontakt
  email     String
  firstName String
  lastName  String
  phone     String @default("")

  // Firma (volitelné — pro B2B zákazníky)
  companyName String?
  ico         String?
  dic         String?

  // Fakturační adresa
  billingAddressLine1 String  @default("")
  billingAddressLine2 String  @default("")
  billingCity         String  @default("")
  billingPostalCode   String  @default("")
  billingCountry      String  @default("CZ")

  // Dodací adresa (null = stejná jako fakturační, nebo výdejní místo Zásilkovny)
  addressLine1 String  @default("")
  addressLine2 String  @default("")
  city         String  @default("")
  postalCode   String  @default("")
  country      String  @default("CZ")
  carrier      Carrier @default(ZASILKOVNA)

  // Platba
  totalAmount      Int // v haléřích
  paymentMethod    PaymentMethod @default(BANK_TRANSFER)
  paymentReference String? // variabilní symbol pro bankovní převod
  stripePaymentId  String?       @unique

  // Zásilkovna
  pickupPointId   String? // ID výdejního místa Zásilkovny
  pickupPointName String? // Název výdejního místa (pro zobrazení)
  packetaId       String? // Barcode zásilky vrácený Zásilkovnou po vytvoření
  trackingNumber  String? // Číslo pro sledování zásilky

  // Stav
  status    OrderStatus @default(PENDING_PAYMENT)
  notes     String      @default("")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  items        OrderItem[]
  certificates Certificate[]
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id])
  editionId         String
  edition           Edition  @relation(fields: [editionId], references: [id])
  certificateNumber Int
  price             Int // cena v haléřích v době objednávky
  createdAt         DateTime @default(now())

  certificate Certificate?
}

enum Carrier {
  ZASILKOVNA
  CZECH_POST
  DPD
  PPL
  TOP_TRANS
}

enum PaymentMethod {
  BANK_TRANSFER
  STRIPE
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Certificate {
  id           String    @id @default(cuid())
  orderId      String
  order        Order     @relation(fields: [orderId], references: [id])
  orderItemId  String    @unique
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id])
  serialNumber String // např. "LE-0042/50"
  printedAt    DateTime  @default(now())
}
